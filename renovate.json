{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended",
    ":dependencyDashboard",
    ":timezone(Europe/Oslo)"
  ],

  "enabledManagers": ["flux"],

  "flux": {
    "fileMatch": ["(^|/).*\\.ya?ml$"]
  },

  "packageRules": [
    {
      "matchManagers": ["flux"],
      "groupName": "Flux updates"
    }
  ]
}
