{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended",
    "docker:enableMajor",
    ":timezone(Europe/Oslo)",
    ":ignoreUnstable"
  ],
  "dependencyDashboard": false,
  "enabledManagers": [
    "flux",
    "kubernetes"
  ],
  "flux": {
    "managerFilePatterns": [
      "^cluster/.+\\.ya?ml$"
    ]
  },
  "kubernetes": {
    "managerFilePatterns": [
      "^cluster/.+\\.ya?ml$"
    ]
  },
  "customManagers": [
    {
      "customType": "regex",
      "description": "Update dependencies with renovate annotations in YAML files",
      "managerFilePatterns": [
        "^cluster/.+\\.ya?ml$"
      ],
      "matchStrings": [
        "#\\s*renovate:\\s*datasource=(?<datasource>[a-zA-Z0-9-._]+)\\s+depName=(?<depName>[^\\s]+?)(?:\\s+versioning=(?<versioning>[a-zA-Z0-9-._]+?))?(?:\\s+registryUrl=(?<registryUrl>[^\\s]+?))?\\s+[A-Za-z0-9_-]+:\\s*[\"']?(?<currentValue>[^\"'\\s]+)[\"']?"
      ],
      "versioningTemplate": "{{#if versioning}}{{{versioning}}}{{else}}semver-coerced{{/if}}"
    }
  ],
  "packageRules": [
    {
      "description": "Only allow semver-like Docker tags",
      "matchDatasources": ["docker"],
      "allowedVersions": "/^v?[0-9]+\\.[0-9]+\\.[0-9]+(\\.[0-9]+)?([-.][0-9A-Za-z]+)*$/"
    }
  ],
  "prConcurrentLimit": 0,
  "prHourlyLimit": 0,
  "schedule": ["at any time"]
}