{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended",
    ":dependencyDashboard",
    ":timezone(Europe/Oslo)"
  ],

  "enabledManagers": ["flux"],

  "flux": {
    // Tell the Flux manager to scan ALL .yaml/.yml files
    "managerFilePatterns": [
      "/\\.ya?ml$/"
    ]
  },

  "packageRules": [
    {
      "matchManagers": ["flux"],
      "groupName": "Flux updates"
    }
  ]
}
