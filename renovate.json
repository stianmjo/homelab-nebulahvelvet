{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended",
    "docker:enableMajor",
    ":timezone(Europe/Oslo)",
    ":ignoreUnstable"
  ],

  "dependencyDashboard": false,

  "enabledManagers": ["flux", "kubernetes"],

  "flux": {
    "fileMatch": ["^cluster/.+\\.ya?ml$"]
  },
  "kubernetes": {
    "fileMatch": ["^cluster/.+\\.ya?ml$"]
  },

  "packageRules": [
    {
      "matchDatasources": ["docker"],
      "allowedVersions": "/^v?[0-9]+\\.[0-9]+\\.[0-9]+(\\.[0-9]+)?([-.][0-9A-Za-z]+)*$/"
    },
    {
      "matchDatasources": ["docker"],
      "matchPackageNames": ["ghcr.io/stianmjo/proton-bridge"],
      "enabled": false
    }
  ]
}
