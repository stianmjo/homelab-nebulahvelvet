{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended",
    "docker:enableMajor",
    ":timezone(Europe/Oslo)",
    ":ignoreUnstable"
  ],
  "dependencyDashboard": false,
  "flux": {
    "fileMatch": ["^cluster/.+\\.ya?ml$"]
  },
  "kubernetes": {
    "fileMatch": ["^cluster/.+\\.ya?ml$"]
  },
  "packageRules": [
    {
      "description": "Only allow semver-like Docker tags",
      "matchDatasources": ["docker"],
      "allowedVersions": "/^v?[0-9]+\\.[0-9]+\\.[0-9]+(\\.[0-9]+)?([-.][0-9A-Za-z]+)*$/"
    },
    {
      "description": "Ignore gjallar - managed manually",
      "matchDatasources": ["docker"],
      "matchPackageNames": ["git.nebulahvelvet.no/stianmjo/gjallar"],
      "enabled": false
    }
  ],
  "prConcurrentLimit": 0,
  "prHourlyLimit": 0,
  "schedule": ["at any time"]
}